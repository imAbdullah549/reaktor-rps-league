# Optional. Leave unset in development (Vite proxies /api to backend).
# On Vercel (or any host where frontend and backend are different origins), set to your backend API base including /api, e.g.:
# VITE_API_URL=https://reaktor-rps-league.up.railway.app/api

# Optional. Set to true to use UTC for all dates (e.g. for assignment submission: "All questions assume UTC timezone").
# VITE_USE_UTC=true
