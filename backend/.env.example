# Copy this file to .env and set your values.
# Never commit .env to version control.

# Set to "production" when deploying. Dev routes (/dev/*) are disabled in production.
NODE_ENV=development

# Bearer token for BAD API (assignments.reaktor.com)
BEARER_TOKEN=your_token_here

# Port for the backend server (default: 3001)
PORT=3001

# In production, allowed CORS origins (comma-separated). Omit to allow all.
# FRONTEND_ORIGIN=https://your-app.vercel.app,https://your-app.netlify.app

# Cache: max history pages to load on startup (default: 30). Use 0 to fetch all pages until no cursor.
CACHE_MAX_PAGES=0

# Delay in ms between history page requests to avoid 429 rate limiting (default: 600).
HISTORY_FETCH_DELAY_MS=600

# Max retries when API returns 429 Too Many Requests (default: 3).
HISTORY_429_MAX_RETRIES=3

# Grace period in ms for graceful shutdown on SIGTERM/SIGINT (default: 10000).
# SHUTDOWN_GRACE_MS=10000

# Delay in ms before reconnecting to BAD API live stream after disconnect (default: 5000).
LIVE_RECONNECT_MS=5000
